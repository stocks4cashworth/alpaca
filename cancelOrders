/**
 * Safely cancels ONLY the open orders matching the specific ticker symbol in cell D4.
 * Status written to B1 | Details written to B2
 */
function cancelOrdersByTicker() {
  const ss = SpreadsheetApp.getActiveSpreadsheet();
  const sheet = ss.getSheetByName("Main");
  if (!sheet) return;

  // 1. Reset Status
  sheet.getRange("B1").setValue("Cancelling...");
  sheet.getRange("B2").clearContent();

  // 2. Normalize Ticker from D4
  const ticker = sheet.getRange("D4").getValue().toString().toUpperCase().trim();
  if (!ticker) {
    sheet.getRange("B1").setValue("Input Error");
    sheet.getRange("B2").setValue("Enter a ticker in D4.");
    return;
  }

  // 3. Retrieve all open orders using your existing internal functions
  // listOrders() is globally available in your project and pulls your active order book
  var allOrders = listOrders();
  var openStatuses = ['new', 'partially_filled', 'pending_cancel', 'accepted', 'pending_new', 'accepted_for_bidding'];
  
  // Filter for open orders that match our target ticker exactly
  var targetOrders = allOrders.filter(function(order) {
    return order.symbol === ticker && openStatuses.indexOf(order.status) !== -1;
  });

  if (targetOrders.length === 0) {
    sheet.getRange("B1").setValue("No Orders");
    sheet.getRange("B2").setValue("No open orders found for " + ticker + ".");
    return;
  }

  sheet.getRange("B2").setValue("Found " + targetOrders.length + " order(s). Cancelling...");

  // 4. Sequentially cancel each targeted order ID using your internal _cancelRequest helper
  var successCount = 0;
  var failCount = 0;

  targetOrders.forEach(function(order) {
    var result = _cancelRequest(order.id); // Uses your clean DELETE helper function
    if (result.code >= 200 && result.code < 300) {
      successCount++;
    } else {
      failCount++;
      Logger.log("Failed to cancel order " + order.id + " for " + ticker + ". Code: " + result.code);
    }
  });

  // 5. Output Summary Results to Sheet
  if (failCount === 0) {
    sheet.getRange("B1").setValue("Success");
    sheet.getRange("B2").setValue("Cancelled all " + successCount + " open order(s) for " + ticker + ".");
  } else {
    sheet.getRange("B1").setValue("Partial Success");
    sheet.getRange("B2").setValue("Cancelled " + successCount + " order(s). Failed on " + failCount + ".");
  }

  // Auto-refresh the layout to reflect changes immediately
  if (typeof updateSheet === "function") {
    updateSheet();
  }
}

