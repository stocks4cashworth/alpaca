/**
 * Standalone Unified Order Submission
 * Translates F4 options into correct Alpaca Type and Class.
 */
function submitOrder() {
  const ss = SpreadsheetApp.getActiveSpreadsheet();
  const sheet = ss.getSheetByName("Main");
  if (!sheet) return;

  // 1. Reset Status
  sheet.getRange("B1").setValue("Submitting...");
  sheet.getRange("B2").clearContent();

  // 2. Load Credentials
  const props = PropertiesService.getScriptProperties();
  const keyId = props.getProperty('ALPACA_KEY'); 
  const secretKey = props.getProperty('ALPACA_SECRET');

  if (!keyId || !secretKey) {
    sheet.getRange("B1").setValue("Key Error");
    sheet.getRange("B2").setValue("Run 'Setup API Keys' first.");
    return;
  }

  // 3. Extract and Normalize Inputs
  const ticker = sheet.getRange("D4").getValue().toString().toUpperCase().trim();
  const side   = sheet.getRange("E4").getValue().toString().toLowerCase().trim();
  const f4Value = sheet.getRange("F4").getValue().toString().toLowerCase().trim(); // Dropdown Value
  const tif    = sheet.getRange("G4").getValue().toString().toLowerCase().trim() || "gtc";
  const qty    = parseFloat(sheet.getRange("F5").getValue());

  const entryPrice = sheet.getRange("F6").getValue();
  const takeProfit = sheet.getRange("F7").getValue();
  const stopPrice  = sheet.getRange("F8").getValue();
  const stopLimit  = sheet.getRange("F9").getValue();

  if (!ticker || isNaN(qty) || qty <= 0) {
    sheet.getRange("B1").setValue("Input Error");
    sheet.getRange("B2").setValue("Verify Ticker (D4) and Shares (F5).");
    return;
  }

  // 4. LOGIC GATE: Translate F4 into Alpaca 'Type' and 'Order Class'
  let type = "market";       // Default
  let orderClass = "simple"; // Default

  switch (f4Value) {
    case 'market':
      type = "market";
      orderClass = "simple";
      break;
    case 'limit':
      type = "limit";
      orderClass = "simple";
      break;
    case 'stop':
      type = "stop";
      orderClass = "simple";
      break;
    case 'stop_limit':
      type = "stop_limit";
      orderClass = "simple";
      break;
    case 'trailing_stop':
      type = "trailing_stop";
      orderClass = "simple";
      break;
    case 'oco':
      type = "limit"; // OCO must be limit or stop
      orderClass = "oco";
      break;
    case 'bracket_m':
      type = "market";
      orderClass = "bracket";
      break;
    case 'bracket_l':
      type = "limit";
      orderClass = "bracket";
      break;
  }

  // 5. Build Dynamic Payload
  let payload = {
    "symbol": ticker,
    "qty": qty.toString(),
    "side": side,
    "type": type,
    "time_in_force": tif,
    "order_class": orderClass
  };

  // Add Price for Limit orders (Limit, Stop_Limit, or Bracket_L)
  if (type === "limit" || type === "stop_limit") {
    if (entryPrice) payload.limit_price = entryPrice.toString();
  }

  // Add Stop Price for Stop orders
  if (type === "stop" || type === "stop_limit") {
    if (stopPrice) payload.stop_price = stopPrice.toString();
  }

  // Add Legs for Bracket or OCO
  if (orderClass === "bracket" || orderClass === "oco") {
    if (takeProfit) {
      payload.take_profit = { "limit_price": takeProfit.toString() };
    }
    if (stopPrice) {
      payload.stop_loss = { "stop_price": stopPrice.toString() };
      // If a limit is provided in F9, turn the stop loss leg into a stop-limit
      if (stopLimit) payload.stop_loss.limit_price = stopLimit.toString();
    }
  }

  // 6. Execute Request
  const isPaper = keyId.startsWith('PK');
  const baseUrl = isPaper ? "https://paper-api.alpaca.markets" : "https://api.alpaca.markets";
  
  const options = {
    "method": "post",
    "headers": {
      "APCA-API-KEY-ID": keyId,
      "APCA-API-SECRET-KEY": secretKey,
      "Content-Type": "application/json"
    },
    "payload": JSON.stringify(payload),
    "muteHttpExceptions": true
  };

  try {
    const response = UrlFetchApp.fetch(baseUrl + "/v2/orders", options);
    const code = response.getResponseCode();
    const data = JSON.parse(response.getContentText());

    if (code <= 201) {
      sheet.getRange("B1").setValue("Success");
      sheet.getRange("B2").setValue("Order ID: " + data.id);
    } else {
      sheet.getRange("B1").setValue("Failed (" + code + ")");
      sheet.getRange("B2").setValue(data.message || "Unknown error.");
    }
  } catch (e) {
    sheet.getRange("B1").setValue("System Error");
    sheet.getRange("B2").setValue(e.message);
  }
}


/**
 * Advanced Order: Add to Position
 * Queries Alpaca for the latest trade price of the ticker in D4,
 * calculates a limit price 0.005% below that trade price,
 * and submits a bracket order using the share count from D9 (rounded up if fractional)
 * with an attached 2% stop-loss leg.
 */
function addToPosition() {
  var ss = SpreadsheetApp.getActiveSpreadsheet();
  var sheet = ss.getSheetByName("Main");
  if (!sheet) {
    Logger.log("Error: 'Main' sheet not found.");
    return;
  }

  // 1. Reset status cells on the sheet
  sheet.getRange("B1").setValue("Processing...");
  sheet.getRange("B2").clearContent();

  // 2. Fetch and normalize inputs from the sheet
  var ticker = sheet.getRange("D4").getValue().toString().toUpperCase().trim(); // Ticker cell
  var rawQty = parseFloat(sheet.getRange("D9").getValue()); // Share count from D9

  if (!ticker) {
    sheet.getRange("B1").setValue("Input Error");
    sheet.getRange("B2").setValue("Please enter a valid ticker in D4.");
    return;
  }

  if (isNaN(rawQty) || rawQty <= 0) {
    sheet.getRange("B1").setValue("Input Error");
    sheet.getRange("B2").setValue("Please enter a valid share quantity in D9.");
    return;
  }

  // CRITICAL UPDATE: Round up to the next whole share if the input is fractional
  var qty = Math.ceil(rawQty);

  // 3. Setup API credentials and endpoints
  initializeCredentials(); // Loads global variables safely
  var keyId = String(ALPAC_API_KEY_ID || ""); 
  var secretKey = String(ALPAC_API_SECRET_KEY || ""); 
  
  if (!keyId || !secretKey) {
    sheet.getRange("B1").setValue("Key Error");
    sheet.getRange("B2").setValue("Check API Keys in Setup.");
    return;
  }

  // 4. Query Alpaca for the latest trade price
  var dataUrl = "https://data.alpaca.markets/v2/stocks/" + ticker + "/trades/latest?feed=iex"; 
  var fetchOptions = {
    "method": "get",
    "headers": {
      "APCA-API-KEY-ID": keyId,
      "APCA-API-SECRET-KEY": secretKey,
      "Accept": "application/json"
    },
    "muteHttpExceptions": true 
  };

  var lastTradePrice = 0;
  try {
    var response = UrlFetchApp.fetch(dataUrl, fetchOptions); 
    var responseText = response.getContentText(); 
    
    if (responseText.charAt(0) !== '{') { 
      sheet.getRange("B1").setValue("API Error");
      sheet.getRange("B2").setValue("Invalid response feed fetching market price.");
      return;
    }
    
    var priceData = JSON.parse(responseText);
    if (priceData && priceData.trade && priceData.trade.p) {
      lastTradePrice = parseFloat(priceData.trade.p); 
    } else {
      sheet.getRange("B1").setValue("Query Failed");
      sheet.getRange("B2").setValue("No trade data available for " + ticker);
      return;
    }
  } catch (e) {
    sheet.getRange("B1").setValue("System Error");
    sheet.getRange("B2").setValue("Price query failed: " + e.message);
    return;
  }

  // 5. Calculate entry limit price and secondary stop-loss parameter
  // Entry price is 0.05% below the market price (Multiplied by 0.9995)
  var limitEntryPrice = lastTradePrice * 0.9995;
  
  // Stop-loss trigger is set 2% below our limit execution price (Multiplied by 0.98)
  var stopLossPrice = limitEntryPrice * 0.98;

  // Round values cleanly to 2 decimal places for execution compliance
  limitEntryPrice = Math.round(limitEntryPrice * 100) / 100;
  stopLossPrice = Math.round(stopLossPrice * 100) / 100;

  // 6. Build the Bracket Order Payload
  var orderPayload = {
    "symbol": ticker,
    "qty": qty.toString(),
    "side": "buy",
    "type": "limit", // The main order type is a limit order to buy below the market
    "time_in_force": "gtc", // Good 'Til Cancelled ensures protection attaches
    "limit_price": limitEntryPrice.toString(),
    "order_class": "bracket", // Bracket class links multi-leg dependencies
    "stop_loss": {
      "stop_price": stopLossPrice.toString() // Triggers a market order to sell if hit
    }
  };

  // 7. Execute order submission to order desk endpoints
  var isPaper = keyId.startsWith('PK'); 
  var tradeUrl = (isPaper ? "https://paper-api.alpaca.markets" : "https://api.alpaca.markets") + "/v2/orders"; 
  
  var tradeOptions = {
    "method": "post",
    "headers": {
      "APCA-API-KEY-ID": keyId,
      "APCA-API-SECRET-KEY": secretKey,
      "Content-Type": "application/json"
    },
    "payload": JSON.stringify(orderPayload), 
    "muteHttpExceptions": true
  };

  try {
    var orderResponse = UrlFetchApp.fetch(tradeUrl, tradeOptions); 
    var responseCode = orderResponse.getResponseCode(); 
    var orderData = JSON.parse(orderResponse.getContentText()); 

    if (responseCode <= 201) { 
      sheet.getRange("B1").setValue("Success"); 
      sheet.getRange("B2").setValue("Qty: " + qty + " | Limit: $" + limitEntryPrice.toFixed(2) + " | SL: $" + stopLossPrice.toFixed(2));
      Logger.log("Successfully submitted bracket position for " + ticker + ". Parent ID: " + orderData.id);
    } else {
      sheet.getRange("B1").setValue("Failed (" + responseCode + ")"); 
      sheet.getRange("B2").setValue(orderData.message || "Unknown error occurred."); 
    }
  } catch (err) {
    sheet.getRange("B1").setValue("System Error");
    sheet.getRange("B2").setValue(err.message);
  }

  // 8. Refresh portfolio layout view directly
  if (typeof updateSheet === "function") {
    updateSheet(); 
  }
}
